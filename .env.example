# App
ENV=development
API_PORT=8000
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Postgres
POSTGRES_USER=secondbrain
POSTGRES_PASSWORD=secondbrain_password
POSTGRES_DB=secondbrain
DATABASE_URL=postgresql+psycopg://secondbrain:secondbrain_password@postgres:5432/secondbrain

# NVIDIA LLM
NVIDIA_API_KEY=your_nvidia_api_key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_LLM_MODEL=meta/llama-3.1-70b-instruct

# Pinecone
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX=second-brain
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_DIMENSION=1024

# Notion
NOTION_API_KEY=your_notion_secret
NOTION_TASKS_DATABASE_ID=your_notion_tasks_database_id

# OpenWA
OPENWA_BASE_URL=http://openwa-api:2785
OPENWA_API_KEY=change_this_master_key

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
JWT_SECRET=change_this_to_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
